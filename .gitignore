# --- Segurança e Configurações Locais ---
# Ignorar ficheiros de variáveis de ambiente (CRÍTICO)
.env
*.env.local

# --- Backend (Python/Flask) ---
# Ignorar ficheiros compilados do Python
__pycache__/
*.py[cod]
*$py.class
backend/__pycache__/
backend/*/__pycache__/

# Ambientes Virtuais
venv/
.venv/
env/

# --- Banco de Dados ---
# Ignorar o ficheiro de base de dados local
database/*.db
database/*.sqbpro

# --- Frontend (React/Vite) ---
# Ignorar dependências e pastas de build
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Logs de erro do npm/yarn
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Ferramentas e IDEs ---
.vscode/
.idea/
.DS_Store